# Override the upstream Open-Meteo base URLs (e.g. for a self-hosted instance)
OPEN_METEO_URL=https://api.open-meteo.com/v1
OPEN_METEO_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1

# Port the server listens on (used by docker-compose)
PORT=3000

# Optional: set to "production" in deployments
NODE_ENV=development
